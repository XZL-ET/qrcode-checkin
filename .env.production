# ==========================================
# 签到系统 — 生产环境配置
# 复制此文件为 .env 并填入真实值
# ==========================================

# 数据库密码（docker-compose 中 MySQL 密码）
DB_PASSWORD=qiandao-pass
DB_ROOT_PASSWORD=root-pass

# JWT 密钥（务必替换为随机字符串！）
# 生成方式: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-please

# 企业微信配置（必填）
WEWORK_CORP_ID=your-corp-id
WEWORK_CORP_SECRET=your-corp-secret
WEWORK_AGENT_ID=your-agent-id

# 应用外网地址（用于生成二维码中的 URL）
BASE_URL=https://yhfw.gsxhsd.com
